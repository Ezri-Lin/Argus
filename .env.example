# ── Required ──
ARGUS_MODEL_BASE_URL=https://api.openai.com/v1
ARGUS_MODEL_API_KEY=sk-xxx
ARGUS_MODEL_NAME=gpt-4o-mini

# ── Pipeline ──
ARGUS_POLL_INTERVAL_MIN=60
ARGUS_STALE_THRESHOLD_MIN=90

# ── Database ──
ARGUS_DB_PATH=data/argus.db

# ── Optional ──
# TAVILY_API_KEY=              # Deep web search (leave empty to disable)
# ARGUS_API_URL=http://127.0.0.1:8000  # Self-calls from scheduler (default works in Docker)
# ARGUS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173  # Dev CORS origins
